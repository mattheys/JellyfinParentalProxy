@page "/"
@page "/ratings"
@rendermode InteractiveServer

@using Domain.Interfaces
@using Domain.Models
@using MudBlazor
@inject IRatingCache RatingCache
@inject IConfigurationService ConfigurationService
@inject ISnackbar Snackbar

<PageTitle>Ratings Admin</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
        <MudText Typo="Typo.h4">Ratings Admin</MudText>

        <MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
            <MudTextField T="string"
                          Value="_searchText"
                          ValueChanged="OnSearchChanged"
                          Placeholder="Filter cache entries..."
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          Style="min-width:260px" />

            <MudSelect T="string"
                       Label="Max allowed rating"
                       Value="_selectedMaxRating"
                       ValueChanged="OnMaxRatingChangedAsync"
                       Variant="Variant.Outlined"
                       Style="min-width:220px">
                @foreach (var rating in AgeRatingParser.AllRatingStrings)
                {
                    <MudSelectItem T="string" Value="@rating">@rating</MudSelectItem>
                }
            </MudSelect>

            <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                       Variant="Variant.Outlined"
                       OnClick="Reload">
                Refresh
            </MudButton>
        </MudStack>
    </MudStack>

    <MudDataGrid T="CacheEntry"
                 Items="_entries"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Groupable="true"
                 Filterable="true"
                 FilterCaseSensitivity="DataGridFilterCaseSensitivity.CaseInsensitive"
                 QuickFilter="QuickFilter"
                 SortMode="SortMode.Multiple">
        <Columns>
            <PropertyColumn Property="x => x.ItemType" Title="Type" Grouping="true" />
            <PropertyColumn Property="x => x.ItemName" Title="Name" />
            <PropertyColumn Property="x => x.JellyfinId" Title="Jellyfin ID" />
            <TemplateColumn Title="Rating" SortBy="x => (int)x.Rating">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@RatingColor(context.Item.Rating)">
                        @AgeRatingParser.ToDisplayString(context.Item.Rating)
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Source">
                <CellTemplate>
                    @if (context.Item.IsManualOverride)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Manual</MudChip>
                    }
                    else if (context.Item.IsPendingLookup)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">Pending</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Auto</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                <CellTemplate>
                    @if (CanOverride(context.Item))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Warning"
                                       OnClick="@(() => OpenOverrideDialog(context.Item))" />

                        @if (context.Item.IsManualOverride)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.RestartAlt"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => RemoveOverrideAsync(context.Item))" />
                        }
                    }
                    else
                    {
                        <MudTooltip Text="Episodes and seasons inherit rating from their series.">
                            <MudIconButton Icon="@Icons.Material.Filled.Link"
                                           Size="Size.Small"
                                           Disabled="true"
                                           Color="Color.Default" />
                        </MudTooltip>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="CacheEntry" />
        </PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="_dialogOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">Set Manual Rating Override</MudText>
    </TitleContent>
    <DialogContent>
        @if (_dialogEntry is not null)
        {
            <MudText Typo="Typo.body2" Class="mb-3">
                @(_dialogEntry.ItemName ?? _dialogEntry.JellyfinId)
            </MudText>
            <MudSelect T="string" Value="_selectedOverrideRating" ValueChanged="OnOverrideRatingChanged" Label="Rating" Variant="Variant.Outlined">
                @foreach (var rating in AgeRatingParser.AllRatingStrings)
                {
                    <MudSelectItem T="string" Value="@rating">@rating</MudSelectItem>
                }
            </MudSelect>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="CloseOverrideDialog">Cancel</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="ApplyOverrideAsync">Save Override</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CacheEntry> _entries = new();
    private string _searchText = string.Empty;
    private string _selectedMaxRating = "PG-13";

    private bool _dialogOpen;
    private CacheEntry? _dialogEntry;
    private string _selectedOverrideRating = "PG";

    protected override void OnInitialized()
    {
        _selectedMaxRating = NormalizeRating(ConfigurationService.GetValue(nameof(ProxyOptions.MaxRating), "PG-13"));
        Reload();
    }

    private void Reload()
    {
        _entries = RatingCache.GetAllEntries().ToList();
        StateHasChanged();
    }

    private void OnSearchChanged(string value)
    {
        _searchText = value;
    }

    private bool QuickFilter(CacheEntry entry)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
            return true;

        var needle = _searchText.Trim();
        return (entry.ItemName?.Contains(needle, StringComparison.OrdinalIgnoreCase) ?? false)
            || entry.JellyfinId.Contains(needle, StringComparison.OrdinalIgnoreCase)
            || (entry.ItemType?.Contains(needle, StringComparison.OrdinalIgnoreCase) ?? false)
            || AgeRatingParser.ToDisplayString(entry.Rating).Contains(needle, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OnMaxRatingChangedAsync(string value)
    {
        var normalized = NormalizeRating(value);
        _selectedMaxRating = normalized;
        await ConfigurationService.SetValueAsync(nameof(ProxyOptions.MaxRating), normalized);
        Snackbar.Add($"Max allowed rating updated to {normalized}", Severity.Success);
    }

    private void OpenOverrideDialog(CacheEntry entry)
    {
        if (!CanOverride(entry))
            return;

        _dialogEntry = entry;
        _selectedOverrideRating = AgeRatingParser.ToDisplayString(entry.Rating);
        _dialogOpen = true;
    }

    private void CloseOverrideDialog()
    {
        _dialogOpen = false;
        _dialogEntry = null;
    }

    private void OnOverrideRatingChanged(string value)
    {
        _selectedOverrideRating = NormalizeRating(value);
    }

    private async Task ApplyOverrideAsync()
    {
        if (_dialogEntry is null)
            return;

        var rating = AgeRatingParser.Parse(_selectedOverrideRating);
        await RatingCache.StoreManualOverrideAsync(
            _dialogEntry.JellyfinId,
            rating,
            _dialogEntry.ItemName,
            _dialogEntry.ItemType,
            _dialogEntry.ParentSeriesId);

        Snackbar.Add($"Override saved for {_dialogEntry.ItemName ?? _dialogEntry.JellyfinId}", Severity.Success);
        CloseOverrideDialog();
        Reload();
    }

    private async Task RemoveOverrideAsync(CacheEntry entry)
    {
        await RatingCache.RemoveOverrideAsync(entry.JellyfinId);
        Snackbar.Add($"Override removed for {entry.ItemName ?? entry.JellyfinId}", Severity.Info);
        Reload();
    }

    private static string NormalizeRating(string? rating)
    {
        var parsed = AgeRatingParser.Parse(rating);
        return AgeRatingParser.ToDisplayString(parsed);
    }

    private static bool CanOverride(CacheEntry entry) =>
        !string.Equals(entry.ItemType, "Episode", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(entry.ItemType, "Season", StringComparison.OrdinalIgnoreCase);

    private static Color RatingColor(AgeRating rating) => rating switch
    {
        AgeRating.G => Color.Success,
        AgeRating.PG => Color.Success,
        AgeRating.PG13 => Color.Info,
        AgeRating.R => Color.Warning,
        AgeRating.NC17 => Color.Error,
        _ => Color.Default,
    };
}
