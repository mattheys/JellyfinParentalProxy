{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft": "Warning",
      "System": "Warning",
      "Yarp": "Warning"
    }
  },

  // ---------------------------------------------------------------------------
  // All proxy settings can be overridden by environment variables.
  // Environment variable names match the JSON keys (case-insensitive).
  //   JELLYFIN_URL=http://my-nas:8096
  //   MAX_RATING=R
  //   TMDB_API_KEY=abc123
  //   TMDB_REGION=GB
  //   TMDB_RETRY_HOURS=12
  //   TMDB_WORKER_COUNT=2
  //   TMDB_QUEUE_CAPACITY=500
  //   CACHE_PATH=/data/rating_cache.db
  // ---------------------------------------------------------------------------
  "JellyfinUrl": "http://127.0.0.1:8096",
  "MaxRating": "PG",
  "TmdbApiKey": "",
  "TmdbRegion": "US",
  "TmdbRetryHours": 24,

  // Number of concurrent background workers that drain the TMDB lookup queue.
  // Increase if TMDB lookups are slow; keep low to avoid rate-limiting.
  "TmdbWorkerCount": 2,

  // Maximum items held in the lookup queue at once.
  // Oldest items are dropped when full — they will be retried on next request.
  "TmdbQueueCapacity": 500,

  "CachePath": "rating_cache.db",

  // ---------------------------------------------------------------------------
  // YARP reverse proxy
  // ---------------------------------------------------------------------------
  "ReverseProxy": {
    "Routes": {
      "jellyfin-route": {
        "ClusterId": "jellyfin-cluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "jellyfin-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://127.0.0.1:8096"
          }
        }
      }
    }
  }
}
